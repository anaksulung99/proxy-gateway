{
  "name": "proxy-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "lint": "pnpm --dir apps/web lint",
    "typecheck": "pnpm --dir apps/web typecheck",
    "migrate": "pnpm --dir apps/web exec node ace migration:run",
    "migrate:fresh": "pnpm --dir apps/web exec node ace migration:fresh --seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
