# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# SMTP
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Residential Proxy"
SMTP_FROM_EMAIL=noreply@example.com

# Database (PostgreSQL)
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=proxy_system

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Health-check enqueue (RabbitMQ)
HEALTHCHECK_ENQUEUE_ENABLED=false
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Go health-checker (synchronous)
HEALTH_CHECKER_URL=http://127.0.0.1:8003
HEALTH_CHECKER_TARGET_URL=https://api.ipify.org

# Go scraper
SCRAPER_URL=http://127.0.0.1:8002
SCRAPER_SCHEDULER_ENABLED=true
SCRAPER_SCHEDULER_TICK_SECONDS=30
PROXY_USAGE_PRUNER_ENABLED=true
PROXY_USAGE_PRUNER_TICK_SECONDS=3600
PROXY_USAGE_LOG_RETENTION_DAYS=30
# Geo/ASN enrichment (ip-api.com batch)
GEO_ENRICHMENT_ENABLED=true
GEO_ENRICHMENT_TICK_SECONDS=120
GEO_ENRICHMENT_BATCH_LIMIT=200

# Proxy engine gateway
GATEWAY_HOST=127.0.0.1:8000
GATEWAY_SECRET=changeme
PROXY_ENGINE_ADMIN_URL=http://127.0.0.1:8001
INTERNAL_API_SECRET=changeme-internal
