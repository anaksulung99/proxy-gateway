GO_ENV=development
PORT=8001
GATEWAY_PORT=8000
GATEWAY_SECRET=changeme
INTERNAL_API_SECRET=changeme-internal
RUNTIME_FAILURE_THRESHOLD=2
RUNTIME_FAILURE_WINDOW_SEC=300
RUNTIME_AUTO_RECHECK_ENABLED=true
RUNTIME_AUTO_RECHECK_DELAY_SEC=90
RUNTIME_AUTO_RECHECK_MAX_ATTEMPTS=2
RUNTIME_AUTO_RECHECK_RETRY_DELAY_SEC=180

# Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=proxy_system

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/proxy
