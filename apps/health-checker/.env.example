GO_ENV=development
PORT=8003
WORKERS=50
CHECKER_TIMEOUT_SECONDS=15
CHECKER_TEST_URL=https://api.ipify.org

# Enable the RabbitMQ consumer (async import checks)
CONSUMER_ENABLED=false

# Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=proxy_system

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
