# ============================================================
# Residential / Mobile Proxy Platform — Docker .env
#   cp .env.example .env  &&  edit the secrets below
# This single file feeds docker-compose AND every container (env_file).
# ============================================================

# ---- AdonisJS web ----
NODE_ENV=production
TZ=UTC
LOG_LEVEL=info
# REQUIRED. Generate once: docker compose run --rm web node ace generate:key
APP_KEY=
APP_URL=https://proxy.example.com
SESSION_DRIVER=cookie
DB_CONNECTION=pg

# ---- Postgres (container; app talks to it on the internal port 5432) ----
DB_USER=proxy
DB_PASSWORD=change_me_postgres
DB_DATABASE=proxy_system
# Host-published port (localhost-only; reach it via SSH tunnel). Default 5432 is
# fine because no native postgres runs on this server. Change only if it clashes.
POSTGRES_HOST_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=change_me_redis
# Host-published port (localhost-only; SSH tunnel). Default 6379 — no native redis here.
REDIS_HOST_PORT=6379

# ---- RabbitMQ ----
RABBITMQ_USER=proxy
RABBITMQ_PASSWORD=change_me_rabbit
RABBITMQ_VHOST=/proxy
# Host-published ports (native rabbitmq stays on 5672 / 15672)
RABBITMQ_HOST_PORT=5673
RABBITMQ_MGMT_HOST_PORT=15673
# Web enqueues import health-checks to RabbitMQ
HEALTHCHECK_ENQUEUE_ENABLED=true

# ---- Health checker / scraper (used by web for sync calls + connection hints) ----
HEALTH_CHECKER_TARGET_URL=https://api.ipify.org
CHECKER_TEST_URL=https://api.ipify.org
CHECKER_WORKERS=50
SCRAPER_WORKERS=20

# ---- Background jobs (web) ----
SCRAPER_SCHEDULER_ENABLED=true
SCRAPER_SCHEDULER_TICK_SECONDS=30
PROXY_USAGE_PRUNER_ENABLED=true
PROXY_USAGE_PRUNER_TICK_SECONDS=3600
PROXY_USAGE_LOG_RETENTION_DAYS=30
GEO_ENRICHMENT_ENABLED=true
GEO_ENRICHMENT_TICK_SECONDS=120
GEO_ENRICHMENT_BATCH_LIMIT=200

# ---- Proxy gateway ----
PROXY_ENGINE_WORKERS=50
# Runtime failures needed to quarantine a proxy. 1 = mark unhealthy on the first
# gateway failure (best for rotating pools — auto-recheck re-verifies and restores
# false positives). Raise to 2+ to be more tolerant of transient blips.
RUNTIME_FAILURE_THRESHOLD=1
RUNTIME_FAILURE_WINDOW_SEC=300
RUNTIME_AUTO_RECHECK_ENABLED=true
RUNTIME_AUTO_RECHECK_DELAY_SEC=90
RUNTIME_AUTO_RECHECK_MAX_ATTEMPTS=2
RUNTIME_AUTO_RECHECK_RETRY_DELAY_SEC=180
# Host-published proxy ports clients connect to (keep 8000/1080 unless they clash)
GATEWAY_HOST_PORT=8000
SOCKS_HOST_PORT=1080
WEB_HOST_PORT=3333
# Master gateway password (works for any list). Per-team API keys also work.
GATEWAY_SECRET=change_me_gateway_secret
# Shared secret between web and proxy-engine admin API (MUST match on both)
INTERNAL_API_SECRET=change_me_internal_secret
# Shown to users in the connection string — set to your PUBLIC host:port
GATEWAY_HOST=proxy.example.com:8000
GATEWAY_SOCKS_HOST=proxy.example.com:1080

# ---- Mail (team invites / verification) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Residential Proxy"
SMTP_FROM_EMAIL=noreply@example.com

# ---- Monitoring (profile: monitoring) ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000

# ---- Edge / TLS (profile: edge) ----
DOMAIN=proxy.example.com
LETSENCRYPT_EMAIL=admin@example.com

# ============================================================
# Using your NATIVE postgres/redis/rabbitmq instead of containers?
#   1. Remove (or `--scale`) the postgres/redis/rabbitmq services, OR don't run them.
#   2. Point the apps at the host:  add to each service in compose:
#        extra_hosts: ["host.docker.internal:host-gateway"]
#      and override DB_HOST=host.docker.internal DB_PORT=5432 (etc.) per service.
# ============================================================
