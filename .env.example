# ============================================================
# PROXY SYSTEM — Environment Variables Template
# Copy file ini ke .env dan isi nilainya
# JANGAN commit .env ke Git!
# ============================================================

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
APP_NAME="Proxy System"
APP_ENV=development          # development | production
APP_KEY=                     # generate: node ace generate:key
APP_URL=http://localhost
APP_PORT=3333
LOG_LEVEL=debug              # trace | debug | info | warn | error

# ------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=proxyuser
DB_PASSWORD=changeme_db_password
DB_DATABASE=proxydb

# DB connection pool
DB_POOL_MIN=2
DB_POOL_MAX=20

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0

# Redis DB per kegunaan
REDIS_DB_CACHE=0
REDIS_DB_SESSION=1
REDIS_DB_QUEUE=2
REDIS_DB_PUBSUB=3

# Sticky session TTL (detik) — default 10 menit
STICKY_SESSION_TTL=600

# ------------------------------------------------------------
# RABBITMQ
# ------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=proxyuser
RABBITMQ_PASSWORD=changeme_rabbit_password
RABBITMQ_VHOST=/proxy

# Queue names
QUEUE_SCRAPER_JOBS=scraper.jobs
QUEUE_HEALTH_CHECK=healthcheck.jobs
QUEUE_IMPORT_BATCH=import.batch
QUEUE_DLQ_SUFFIX=.dlq

# Consumer concurrency
SCRAPER_WORKER_COUNT=5
HEALTH_CHECK_WORKER_COUNT=20
IMPORT_WORKER_COUNT=10

# ------------------------------------------------------------
# PROXY ENGINE (Go service)
# ------------------------------------------------------------
PROXY_ENGINE_HOST=proxy-engine
PROXY_ENGINE_PORT=8080
PROXY_ENGINE_INTERNAL_API_KEY=changeme_engine_api_key

# HTTP proxy server port
PROXY_HTTP_PORT=3128
# SOCKS5 server port
PROXY_SOCKS5_PORT=1080

# ------------------------------------------------------------
# SCRAPER SERVICE (Go service)
# ------------------------------------------------------------
SCRAPER_HOST=scraper
SCRAPER_PORT=8081
SCRAPER_INTERNAL_API_KEY=changeme_scraper_api_key

# Default scrape interval (jam)
SCRAPER_DEFAULT_INTERVAL_HOURS=6

# Request timeout per scrape source (detik)
SCRAPER_REQUEST_TIMEOUT=30

# ------------------------------------------------------------
# HEALTH CHECKER (Go service)
# ------------------------------------------------------------
CHECKER_HOST=health-checker
CHECKER_PORT=8082
CHECKER_INTERNAL_API_KEY=changeme_checker_api_key

# Default URL untuk test proxy
CHECKER_TEST_URL=https://ifconfig.me/ip
CHECKER_TEST_URL_SECONDARY=https://api.ipify.org

# Playwright browser pool size
PLAYWRIGHT_POOL_SIZE=3
# Timeout per check (detik)
CHECK_TIMEOUT_SECONDS=30

# ------------------------------------------------------------
# TRAEFIK
# ------------------------------------------------------------
TRAEFIK_DASHBOARD_USER=admin
# Generate: htpasswd -nB admin → copy hasilnya
TRAEFIK_DASHBOARD_PASSWORD_HASH=

# Domain utama
DOMAIN=proxy.yourdomain.com
# Email untuk Let's Encrypt
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Aktifkan HTTPS (true di production, false di dev)
TRAEFIK_HTTPS=false

# ------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# Prometheus scrape interval
PROMETHEUS_SCRAPE_INTERVAL=15s

# Loki log retention
LOKI_RETENTION_PERIOD=744h   # 31 hari

# ------------------------------------------------------------
# SESSION & AUTH (AdonisJS)
# ------------------------------------------------------------
SESSION_DRIVER=redis
COOKIE_SECRET=changeme_cookie_secret_min32chars

# Token expiry
API_KEY_PREFIX=pxs_

# ------------------------------------------------------------
# MAIL (untuk team invite)
# ------------------------------------------------------------
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=changeme_smtp_password
SMTP_FROM_NAME="Proxy System"
SMTP_FROM_EMAIL=noreply@yourdomain.com
