# Build context = repo root (used by the web image). Keep it lean.
.git
.github
.gitignore
.trae
.vscode
.idea
**/node_modules
**/tmp
**/*.exe
**/*.log
**/build
**/coverage
**/.cache
**/.turbo
apps/web/.env
apps/web/.env.*
apps/web/storage
apps/web/tests
apps/web/test-results
# Other apps build in their own contexts — not needed for the web image
apps/proxy-engine
apps/scraper
apps/health-checker
docs
*.md
.env
.env.*
